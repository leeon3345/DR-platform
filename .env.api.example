# Copy this file to .env.api and fill in local-only secrets.
# Do not commit .env.api.

API_HOST=0.0.0.0
API_PORT=3001

DR_SSH_PASSWORD=<vm-ssh-password>
LLM_API_KEY=<llm-api-key>

# Optional external URLs used by operators after zrok shares are running.
ZROK_API_URL=https://api-example.zrok.io
ZROK_DASHBOARD_URL=https://dashboard-example.zrok.io

# Optional dashboard build-time API override. Leave empty when using the nginx /api proxy.
VITE_API_BASE_URL=
VITE_API_URL=
